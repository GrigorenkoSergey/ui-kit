{
  "name": "native-spa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "webpack serve --mode development --env mode=development",
    "build": "webpack --mode production --env mode=production",
    "test": "npx playwright test --project=chromium",
    "test-unit": "npx playwright test unit-testing --project=chromium",
    "test-e2e": "npx playwright test e2e --project=chromium",
    "test-ui": "IS_UI_MODE=true npx playwright test --ui",
    "storybook": "npx webpack serve --config src/.storybook/webpack.config.cjs",
    "storybook-build": "npx webpack --mode production --env mode=production --config src/.storybook/webpack.config.cjs",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.54.1",
    "@stylistic/eslint-plugin": "^5.7.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "dotenv": "^17.2.1",
    "eslint": "^9.28.0",
    "globals": "^16.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.101.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
